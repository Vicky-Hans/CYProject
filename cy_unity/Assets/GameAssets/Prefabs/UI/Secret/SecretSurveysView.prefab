  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 0
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u4EB2\u7231\u7684\u5927\u9B54\u6CD5\u5E08\uFF0C\u6211\u662F\u300ABackpack
    Merge\u300B\u9879\u76EE\u56E2\u961F\u7B56\u5212\uFF0C\u9996\u5148\uFF0C\u6211\u60F3\u5BF9\u5927\u5BB6\u8868\u793A\u7531\u8877\u7684\u611F\u8C22\uFF0C\u611F\u8C22\u5927\u5BB6\u5BF9\u6E38\u620F\u7684\u559C\u7231\u548C\u652F\u6301\uFF0C\u5728\u8FD9\u91CC\u6211\u8981\u5927\u5BB6\u8868\u8FBE\u4E00\u4E9B\u91CD\u8981\u4FE1\u606F\uFF0C\u5E76\u5206\u4EAB\u4E00\u4E9B\u540E\u7EED\u8BA1\u5212\u3002\u5E0C\u671B\u80FD\u591F\u5230\u5927\u5BB6\u73CD\u8D35\u610F\u89C1\uFF0C\u5C06\u6E38\u620F\u5F00\u53D1\u66F4\u52A0\u6709\u8DA3\u3002\\n        
    \u672C\u6B21\u53C2\u4E0E\u79D8\u6797\u63A2\u9669\u73A9\u6CD5\u5E76\u586B\u5199\u7528\u7814\u62A5\u544A\u7684\u73A9\u5BB6\uFF0C\u90FD\u5C06\u83B7\u5F97\u94BB\u77F3*100\u5956\u52B1\uFF0C\u6211\u4EEC\u5C06\u5728\u6240\u6709\u53C2\u4E0E\u586B\u5199\u7528\u7814\u53CD\u9988\u73A9\u5BB6\u4E2D\u62BD\u53D650\u540D\u5E78\u8FD0\u73A9\u5BB6\uFF0C\u989D\u5916\u9644\u8D60\u4E00\u4EFD\u7279\u6B8A\u5956\u52B1\uFF0C\u83B7\u5956\u540D\u5355\u4F1A\u5728\u5B98\u65B9DS\u516C\u5E03\u3002\u79D8\u6797\u63A2\u9669\u73A9\u6CD5\u6211\u4EEC\u6CA1\u6709\u7EE7\u7EED\u6CBF\u7528\u80CC\u5305\u683C\u5B50\u6446\u653E\uFF0C\u662F\u56E0\u4E3A\u6E38\u620F\u5185\u73B0\u5728\u683C\u5B50\u6446\u653E\u73A9\u6CD5\u8F83\u591A\uFF0C\u8FD9\u4F1A\u6D88\u8017\u5927\u91CF\u7684\u65F6\u95F4\uFF0C\u6240\u4EE5\u5728\u79D8\u6797\u63A2\u9669\u73A9\u6CD5\uFF0C\u6211\u4EEC\u5E0C\u671B\u80FD\u591F\u505A\u4E00\u4E9B\u66F4\u52A0\u8F7B\u677E\u8BBE\u8BA1\uFF0C\u589E\u52A0\u66F4\u591A\u66F4\u7B80\u5355\u8089\u9E3D\u5143\u7D20\uFF0C\u8BA9\u5927\u5BB6\u80FD\u591F\u66F4\u723D\u5FEB\u81EA\u7531\u7684\u6218\u6597\u4F53\u9A8C\u3002\u5982\u679C\u79D8\u6797\u63A2\u9669\u73A9\u6CD5\u80FD\u591F\u5F97\u5230\u5927\u5BB6\u8BA4\u53EF\uFF0C\u540E\u7EED\u6211\u4EEC\u5C06\u4F1A\u9646\u7EED\u5F00\u653E\u79D8\u6797PVP\u7B49\u7ADE\u6280\u6027\u73A9\u6CD5\uFF0C\u4E0B\u9762\u6211\u4EEC\u5E0C\u671B\u80FD\u591F\u6536\u96C6\u4E00\u4E9B\u73A9\u5BB6\u5B9D\u8D35\u610F\u89C1\u3002\\n        
    \u8C03\u67E5\u95EE\u5377\u94FE\u63A5\uFF1A<link=handler> <color=#ff0000>click
    me!</color></link>"
